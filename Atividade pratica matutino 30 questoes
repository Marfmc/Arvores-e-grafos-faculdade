Exercício 7 - Comparação de DesempenhoA busca sequencial em um vetor de 1000 elementos realiza, em média, 500 operações (n/2). 
Já a busca binária realiza, em média, cerca de 9 a 10 operações  
O algoritmo binário é muito mais eficiente porque divide o problema pela metade a cada passo, mas exige que os dados estejam ordenados.

Exercício 8 

int main() {
    int notas[] = {2, 3, 5, 6, 7, 8, 9, 10};
    int busca, ini=0, fim=7, meio, achou=-1;
    
    scanf("%d", &busca);
    
    while(ini <= fim) {
        meio = (ini+fim)/2;
        if(notas[meio] == busca) {
            achou = meio;
            break;
        }
        if(notas[meio] < busca) ini = meio + 1;
        else fim = meio - 1;
    }
    
    if(achou != -1) {
        printf("Existem %d alunos com nota maior", 7 - achou);
    }
    return 0;
}
Exercício 9 
int busca(int v[], int n, int x) {
    int i = 0, f = n-1, m;
    while(i <= f) {
        m = (i+f)/2;
        if(v[m] == x) return m;
        if(v[m] < x) i = m + 1;
        else f = m - 1;
    }
    return -1;
}

int main() {
    int v[] = {5, 10, 15, 20, 25, 30};
    printf("%d", busca(v, 6, 20));
    return 0;
}

