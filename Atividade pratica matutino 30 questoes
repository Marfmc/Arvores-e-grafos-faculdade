Exercício 3 

int main() {
    int livros[] = {10, 23, 35, 47, 59, 62, 78, 91};
    int ini = 0, fim = 7, meio, busca, cont = 0;
    
    scanf("%d", &busca);
    
    while(ini <= fim) {
        cont++;
        meio = (ini + fim) / 2;
        if(livros[meio] == busca) {
            printf("Livro encontrado. Iteracoes: %d", cont);
            return 0;
        }
        if(livros[meio] < busca) ini = meio + 1;
        else fim = meio - 1;
    }
    printf("Nao encontrado. Iteracoes: %d", cont);
    return 0;
}
